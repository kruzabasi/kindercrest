---
type IconName = 'heart' | 'spark' | 'users' | 'shield' | 'book' | 'hand' | 'arrow' | 'menu' | 'instagram';

interface Props {
  name: IconName;
  class?: string;
}

const { name, class: className = '' } = Astro.props;
---

<svg
  class:list={['icon', className]}
  aria-hidden="true"
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  {
    name === 'heart' && (
      <path
        d="M20.2 5.7c-1.7-1.9-4.5-2-6.3-.2L12 7.4l-1.9-1.9C8.3 3.7 5.5 3.8 3.8 5.7c-1.7 1.9-1.6 4.8.2 6.6l8 7.7 8-7.7c1.8-1.8 1.9-4.7.2-6.6Z"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === 'spark' && (
      <>
        <path d="M12 3l1.6 5.2L19 10l-5.4 1.8L12 17l-1.6-5.2L5 10l5.4-1.8L12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        <path d="M5 15l.8 2.4L8 18l-2.2.6L5 21l-.8-2.4L2 18l2.2-.6L5 15Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
      </>
    )
  }
  {
    name === 'users' && (
      <>
        <path d="M8.5 12a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z" stroke="currentColor" stroke-width="1.8" />
        <path d="M15.5 11a3 3 0 1 0 0-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M3 20c.8-3.2 2.7-5 5.5-5s4.7 1.8 5.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M14.5 15.2c2.7.4 4.5 2 5.2 4.8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </>
    )
  }
  {
    name === 'shield' && (
      <path
        d="M12 3 5 5.6v5.5c0 4.4 2.8 8 7 9.9 4.2-1.9 7-5.5 7-9.9V5.6L12 3Z"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === 'book' && (
      <>
        <path d="M5 5.5c0-1 1-1.6 2-1.3l5 1.4v14l-5-1.4c-1-.3-2 .3-2 1.3v-14Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
        <path d="M12 5.6 17 4.2c1-.3 2 .3 2 1.3v14c0-1-1-1.6-2-1.3L12 19.6" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
      </>
    )
  }
  {
    name === 'hand' && (
      <>
        <path d="M7 12.5V6a1.5 1.5 0 0 1 3 0v5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M10 11V4.8a1.5 1.5 0 0 1 3 0V11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M13 11V6.2a1.5 1.5 0 0 1 3 0v6.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M7 12.5 5.9 11a1.6 1.6 0 0 0-2.5 1.9l4 5.3A6 6 0 0 0 12.2 21H13a6 6 0 0 0 6-6v-4.8a1.5 1.5 0 0 0-3 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </>
    )
  }
  {
    name === 'arrow' && (
      <>
        <path d="M5 12h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="m13 6 6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </>
    )
  }
  {
    name === 'menu' && (
      <>
        <path d="M4 7h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M4 12h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        <path d="M4 17h16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
      </>
    )
  }
  {
    name === 'instagram' && (
      <>
        <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.9" />
        <circle cx="12" cy="12" r="4.1" stroke="currentColor" stroke-width="1.9" />
        <circle cx="17.4" cy="6.6" r="1" fill="currentColor" />
      </>
    )
  }
</svg>

<style>
  .icon {
    width: 1.35rem;
    height: 1.35rem;
    flex: 0 0 auto;
  }
</style>
