---
import { socialLinks as defaultSocialLinks, type SocialLink } from '../../data/site';
import Icon from './Icon.astro';

interface Props {
  links?: SocialLink[];
  class?: string;
  linkClass?: string;
}

const { links = defaultSocialLinks, class: className = '', linkClass = '' } = Astro.props;
---

<div class:list={['social-links', className]} aria-label="Social links">
  {
    links.map((social) => (
      <a class:list={['social-links__link', linkClass]} href={social.href} target="_blank" rel="noreferrer" aria-label={social.label}>
        <Icon name={social.icon} />
      </a>
    ))
  }
</div>
