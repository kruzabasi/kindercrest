---
import { socialLinks as defaultSocialLinks, type SocialLink } from '../../data/site';
import Icon from './Icon.astro';

interface Props {
  links?: SocialLink[];
  class?: string;
  linkClass?: string;
}

const { links = defaultSocialLinks, class: className = '', linkClass = '' } = Astro.props;
---

<div class:list={['social-links', className]} aria-label="Social links">
  {
    links.map((social) => (
      <a class:list={['social-links__link', linkClass]} href={social.href} target="_blank" rel="noreferrer" aria-label={social.label}>
        <Icon name={social.icon} />
      </a>
    ))
  }
</div>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }

  .social-links__link {
    display: inline-grid;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    color: inherit;
    text-decoration: none;
  }

  .social-links__link::after {
    display: none;
  }

  .social-links__link svg {
    width: 100%;
    height: 100%;
  }
</style>
