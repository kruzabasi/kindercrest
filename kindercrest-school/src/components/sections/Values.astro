---
import { valueCards } from '../../data/site';
---

<section class="values" id="values" aria-labelledby="values-title">
  <div class="container values__shell">
    <div class="values__intro">
      <h2 id="values-title">Why Kindercrest?</h2>
      <p>
        Kindercrest School stands out as an exceptional choice for early childhood education, providing a
        nurturing and purposeful environment where all members of the school community can inspire,
        imagine, believe and achieve.
      </p>
    </div>

    <div class="values__grid" aria-label="Why Kindercrest reasons">
      {
        valueCards.map((value) => (
          <article class:list={['value-item', `value-item--${value.accent}`]}>
            {
              value.illustration && (
                <div class="value-item__illustration" aria-hidden="true">
                  <img
                    src={value.illustration}
                    alt=""
                    width="960"
                    height="720"
                    loading="lazy"
                  />
                </div>
              )
            }

            <h3>{value.title}</h3>
            <p>{value.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .values {
    padding-block: clamp(5rem, 9vw, 8rem);
    color: var(--kc-ink);
    font-family: var(--font-body);
    background:
      linear-gradient(180deg, rgb(247 248 250 / 100%) 0%, rgb(255 255 255 / 100%) 24%, rgb(255 255 255 / 100%) 100%);
  }

  .values__shell {
    display: grid;
    gap: clamp(3.4rem, 7vw, 5.8rem);
  }

  .values__intro {
    display: grid;
    grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: end;
  }

  .values h2 {
    max-width: 560px;
    margin: 0;
    color: var(--kc-navy);
    font-size: clamp(3.1rem, 5.9vw, 4.8rem);
    font-weight: 620;
    letter-spacing: 0;
    line-height: 0.98;
    text-wrap: balance;
  }

  .values__intro p {
    max-width: 620px;
    margin: 0;
    color: color-mix(in srgb, var(--kc-ink) 74%, white);
    font-size: clamp(1.03rem, 1.45vw, 1.18rem);
    line-height: 1.66;
  }

  .values__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(2rem, 5.5vw, 5rem);
    align-items: start;
  }

  .value-item {
    --item-accent: var(--kc-gold);

    min-width: 0;
  }

  .value-item__illustration {
    display: flex;
    width: 100%;
    height: clamp(10.75rem, 15vw, 12rem);
    align-items: center;
    justify-content: center;
    margin-bottom: clamp(1.4rem, 3vw, 2rem);
  }

  .value-item__illustration img {
    width: auto;
    height: 100%;
    max-width: 100%;
    object-fit: contain;
    object-position: center center;
  }

  .value-item h3 {
    margin: 0;
    color: var(--kc-ink);
    font-size: clamp(1.45rem, 2.2vw, 2rem);
    font-weight: 650;
    letter-spacing: 0;
    line-height: 1.12;
  }

  .value-item p {
    max-width: 24rem;
    margin: 0.85rem 0 0;
    color: color-mix(in srgb, var(--kc-ink) 78%, white);
    font-size: clamp(0.98rem, 1.25vw, 1.05rem);
    line-height: 1.72;
  }

  .value-item--gold {
    --item-accent: color-mix(in srgb, var(--kc-gold) 72%, var(--kc-navy));
  }

  .value-item--magenta {
    --item-accent: var(--kc-magenta);
  }

  .value-item--green {
    --item-accent: var(--kc-green);
  }

  @media (max-width: 920px) {
    .values__intro,
    .values__grid {
      grid-template-columns: 1fr;
    }

    .values__intro {
      gap: 1.2rem;
    }

    .values__grid {
      gap: 2.4rem;
    }

    .value-item {
      display: grid;
      grid-template-columns: 8rem minmax(0, 1fr);
      gap: 1.3rem;
      align-items: start;
      border-top: 1px solid color-mix(in srgb, var(--kc-ink) 11%, white);
      padding-top: 2rem;
    }

    .value-item:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .value-item__illustration {
      width: 8rem;
      height: 8rem;
      justify-content: center;
      margin-bottom: 0;
    }

    .value-item__illustration img {
      width: 100%;
      height: 100%;
    }
  }

  @media (max-width: 620px) {
    .values {
      padding-block: 4rem;
    }

    .values__shell {
      gap: 2.6rem;
    }

    .values h2 {
      font-size: 2.35rem;
      line-height: 1.04;
    }

    .values__intro p,
    .value-item p {
      font-size: 0.98rem;
    }

    .value-item {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding-top: 1.7rem;
    }

    .value-item__illustration {
      width: 8.4rem;
      height: 8.4rem;
    }

    .value-item h3 {
      font-size: 1.5rem;
    }
  }
</style>
