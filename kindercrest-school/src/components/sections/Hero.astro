---
import HeroPicture from './HeroPicture.astro';
import { heroSlides } from '../../data/site';

const slideDuration = 6000;
const slideHoldRatio = 0.7;
const holdDuration = Math.round(slideDuration * slideHoldRatio);
const fadeDuration = slideDuration - holdDuration;
const fallbackSlide = heroSlides[0];

if (!fallbackSlide) {
  throw new Error('The homepage hero requires at least one slide.');
}

const heroStyle = [
  `--hero-slide-duration: ${slideDuration}ms`,
  `--hero-fade-duration: ${fadeDuration}ms`
].join('; ');
---

<section class="hero" id="home" aria-labelledby="hero-title" style={heroStyle} data-hero>
  <div
    class="hero__slideshow"
    aria-hidden="true"
    data-hero-slideshow
    data-hold-duration={holdDuration}
    data-fade-duration={fadeDuration}
  >
    <div class="hero__slide is-current" data-hero-layer>
      <HeroPicture {...fallbackSlide} eager />
    </div>
    <div class="hero__slide" data-hero-layer></div>

    {
      heroSlides.map((slide, index) => (
        <template data-hero-slide-template={index}>
          <HeroPicture {...slide} />
        </template>
      ))
    }
  </div>
  <div class="hero__shade" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__main">
      <h1 id="hero-title">Creche, Preschool &amp; Primary</h1>
      <div class="hero__supporting">
        <p class="hero__meta">* In the Heart of Abuja. Established 2010</p>
        <div class="hero__progress" aria-hidden="true">
          <span class="hero__progress-count">
            <span data-hero-slide-current>01</span>
            <span class="hero__progress-separator">/</span>
            <span>{String(heroSlides.length).padStart(2, '0')}</span>
          </span>
          <span class="hero__progress-track">
            <span class="hero__progress-fill" data-hero-progress></span>
          </span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initializeHero } from '../../scripts/hero-slideshow';

  document.querySelectorAll<HTMLElement>('[data-hero]').forEach(initializeHero);
</script>

<style>
  .hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    overflow: hidden;
    color: var(--kc-white);
    font-family: var(--font-body);
    background: var(--kc-navy);
  }

  .hero__slideshow,
  .hero__slide,
  .hero__shade {
    position: absolute;
    inset: 0;
  }

  .hero__slide {
    z-index: 0;
    opacity: 0;
    transition: opacity var(--hero-fade-duration) ease-in-out;
  }

  .hero__slide.is-current {
    z-index: 1;
    opacity: 1;
  }

  .hero__slide.is-entering {
    z-index: 2;
    opacity: 1;
  }

  .hero__slide.is-leaving {
    opacity: 0;
  }

  .hero__slide :global(picture),
  .hero__slide :global(img) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero__slide :global(img) {
    object-fit: cover;
    transform: scale(1);
  }

  .hero.is-enhanced .hero__slide.is-current :global(img) {
    animation: hero-zoom var(--hero-slide-duration) ease-out forwards;
  }

  @keyframes hero-zoom {
    to {
      transform: scale(1.08);
    }
  }

  .hero__shade {
    z-index: 3;
    background:
      linear-gradient(90deg, rgb(0 0 0 / 54%) 0%, rgb(0 0 0 / 30%) 46%, rgb(0 0 0 / 52%) 100%),
      linear-gradient(180deg, rgb(0 0 0 / 22%) 0%, rgb(0 0 0 / 10%) 46%, rgb(0 0 0 / 54%) 100%);
  }

  .hero__content {
    position: relative;
    z-index: 4;
    display: grid;
    width: min(1920px, calc(100% - (clamp(1.4rem, 3.6vw, 5.6rem) * 2)));
    min-height: 100svh;
    align-items: end;
    margin-inline: auto;
    padding: clamp(8rem, 15vh, 12rem) 0 clamp(3.6rem, 8vh, 6rem);
  }

  .hero__main {
    display: grid;
    max-width: min(1100px, calc(100vw - 3rem));
    gap: clamp(1rem, 2.2vw, 1.55rem);
  }

  .hero h1 {
    max-width: 1120px;
    margin: 0;
    color: var(--kc-white);
    font-family: var(--font-body);
    font-size: clamp(4rem, 6.25vw, 8.4rem);
    font-weight: 430;
    letter-spacing: 0.08em;
    line-height: 1.08;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .hero__meta {
    margin: 0;
    color: rgb(255 255 255 / 90%);
    font-size: clamp(0.9rem, 1.15vw, 1.08rem);
    font-weight: 430;
    line-height: 1.35;
  }

  .hero__supporting {
    display: grid;
    width: fit-content;
    gap: 0.85rem;
  }

  .hero__progress {
    display: none;
    align-items: center;
    gap: 0.75rem;
    color: rgb(255 255 255 / 82%);
    font-size: 0.7rem;
    font-variant-numeric: tabular-nums;
    font-weight: 560;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .hero.is-enhanced .hero__progress {
    display: flex;
  }

  .hero__progress-count {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    min-width: 3.7rem;
  }

  .hero__progress-separator {
    color: rgb(255 255 255 / 48%);
  }

  .hero__progress-track {
    display: block;
    width: clamp(5.5rem, 7vw, 7.5rem);
    height: 1px;
    overflow: hidden;
    background: rgb(255 255 255 / 30%);
  }

  .hero__progress-fill {
    display: block;
    width: 100%;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: var(--kc-sky);
  }

  .hero__progress-fill.is-running {
    animation: hero-progress var(--hero-slide-duration) linear forwards;
  }

  @keyframes hero-progress {
    to {
      transform: scaleX(1);
    }
  }

  @media (max-width: 900px) {
    .hero__shade {
      background:
        linear-gradient(90deg, rgb(0 0 0 / 58%) 0%, rgb(0 0 0 / 32%) 66%, rgb(0 0 0 / 38%) 100%),
        linear-gradient(180deg, rgb(0 0 0 / 24%) 0%, rgb(0 0 0 / 14%) 45%, rgb(0 0 0 / 58%) 100%);
    }

    .hero__content {
      width: min(100% - 2rem, 680px);
      padding: 7.5rem 0 3.5rem;
    }

    .hero h1 {
      font-size: clamp(3.05rem, 13.5vw, 5.15rem);
      letter-spacing: 0.055em;
      line-height: 1.04;
    }
  }

  @media (min-width: 901px) {
    .hero__main {
      max-width: min(1120px, calc(100vw - 24rem));
    }
  }

  @media (max-width: 560px) {
    .hero__content {
      padding-bottom: 3rem;
    }

    .hero h1 {
      font-size: clamp(2.62rem, 13vw, 4.2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__slide,
    .hero__slide :global(img) {
      transition: none;
      animation: none;
    }

    .hero__progress {
      display: none;
    }
  }
</style>
