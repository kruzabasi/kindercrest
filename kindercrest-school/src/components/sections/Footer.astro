---
import { contact, footerColumns, getMailtoHref } from '../../data/site';
import SocialLinks from '../ui/SocialLinks.astro';
---

<footer class="footer" id="contact">
  <div class="footer__inner">
    <div class="footer__identity">
      <a class="footer__brand-lockup" href="/" aria-label="Kindercrest School home">
        <img src="/assets/logo/kclogo.png" alt="" width="688" height="688" />
        <span>Kindercrest<br />School</span>
      </a>

      <address class="footer__contact">
        <div>
          <p>Address:</p>
          {contact.addressLines.map((line) => <span>{line}</span>)}
        </div>
        <div>
          <p>Contact:</p>
          {contact.phones.map((phone) => <a href={`tel:${phone}`}>{phone}</a>)}
          <a href={getMailtoHref()}>{contact.email}</a>
        </div>
      </address>

      <SocialLinks class="footer__socials" linkClass="footer__social-link" />
    </div>

    <div class="footer__links">
      {
        footerColumns.map((column) => (
          <nav class="footer__column" aria-label={column.title}>
            <h2>{column.title}</h2>
            {column.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </nav>
        ))
      }
    </div>

    <div class="footer__bottom">
      <p>&copy; 2026 Kindercrest School. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: clamp(4.7rem, 7vw, 6.4rem) clamp(1.5rem, 3vw, 2rem);
    color: var(--kc-ink);
    background: color-mix(in srgb, var(--kc-paper) 82%, var(--kc-white));
  }

  .footer__inner {
    --footer-gutter: clamp(3rem, 5vw, 5rem);

    display: grid;
    width: min(1880px, calc(100% - (var(--footer-gutter) * 2)));
    grid-template-columns: minmax(390px, 0.88fr) minmax(0, 1.12fr);
    column-gap: clamp(6rem, 13vw, 14rem);
    row-gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
    margin-inline: auto;
  }

  .footer__identity {
    display: grid;
    align-content: start;
    justify-items: start;
    gap: clamp(2rem, 3.4vw, 2.7rem);
  }

  .footer__brand-lockup {
    display: inline-grid;
    grid-template-columns: auto auto;
    gap: clamp(0.88rem, 1.35vw, 1.18rem);
    align-items: center;
    color: var(--kc-ink);
  }

  .footer__brand-lockup img {
    width: clamp(96px, 8vw, 116px);
    height: auto;
  }

  .footer__brand-lockup span {
    max-width: 180px;
    font-size: clamp(1.24rem, 1.55vw, 1.46rem);
    font-weight: 560;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .footer__contact {
    display: grid;
    gap: clamp(1.5rem, 2.6vw, 2rem);
    font-style: normal;
  }

  .footer__contact div {
    display: grid;
    gap: 0.18rem;
  }

  .footer__contact p {
    margin: 0 0 0.22rem;
    color: var(--kc-ink);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    font-weight: 560;
    line-height: 1.28;
  }

  .footer__contact a,
  .footer__contact span {
    width: fit-content;
    color: var(--kc-ink);
    font-size: clamp(1rem, 1.35vw, 1.12rem);
    line-height: 1.5;
    font-style: normal;
    font-weight: 400;
  }

  .footer__contact a:hover,
  .footer__column a:hover,
  .footer__bottom a:hover {
    color: var(--kc-navy);
  }

  .footer__socials {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-top: -0.55rem;
  }

  .footer__social-link {
    display: grid;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    color: var(--kc-ink);
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .footer__social-link:hover {
    color: var(--kc-sky);
    transform: translateY(-1px);
  }

  .footer__social-link svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .footer__links {
    display: grid;
    grid-template-columns: minmax(190px, 1.1fr) minmax(220px, 1fr) minmax(180px, 0.9fr);
    gap: clamp(2.25rem, 4vw, 4.8rem);
    padding-top: 0.16rem;
  }

  .footer__column {
    display: grid;
    align-content: start;
    gap: clamp(0.98rem, 1.7vw, 1.25rem);
  }

  .footer__column h2 {
    margin: 0;
    color: var(--kc-ink);
    font-size: clamp(1rem, 1.38vw, 1.18rem);
    font-weight: 540;
    line-height: 1.18;
    white-space: nowrap;
  }

  .footer__column a {
    width: fit-content;
    color: var(--kc-ink);
    font-size: clamp(1rem, 1.38vw, 1.18rem);
    font-weight: 400;
    line-height: 1.24;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .footer__column a:hover {
    transform: translateX(2px);
  }

  .footer__bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-self: end;
    margin: 0;
    border-top: 1px solid color-mix(in srgb, var(--kc-ink) 18%, white);
    padding-top: clamp(1rem, 2vw, 1.25rem);
    color: var(--kc-muted);
    font-size: 0.86rem;
  }

  .footer__bottom p {
    margin: 0;
  }

  @media (min-width: 981px) {
    .footer__inner {
      --footer-gutter: clamp(4.5rem, 6.5vw, 7rem);
    }
  }

  @media (max-width: 980px) {
    .footer__inner {
      --footer-gutter: var(--gutter);

      grid-template-columns: 1fr;
      gap: clamp(3rem, 7vw, 4rem);
    }

    .footer__links {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .footer {
      padding-block: 3.5rem 1.5rem;
    }

    .footer__identity {
      gap: 1.9rem;
    }

    .footer__brand-lockup {
      gap: 0.8rem;
    }

    .footer__brand-lockup img {
      width: 86px;
    }

    .footer__brand-lockup span {
      max-width: 150px;
      font-size: 1.18rem;
      font-weight: 540;
      line-height: 1.1;
    }

    .footer__socials {
      margin-top: -0.35rem;
    }

    .footer__links {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem 1.5rem;
    }

    .footer__column {
      gap: 0.78rem;
    }

    .footer__column:first-child {
      grid-column: 1 / -1;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 1.5rem;
    }

    .footer__column:first-child h2 {
      grid-column: 1 / -1;
    }

    .footer__bottom {
      margin-top: 2.5rem;
    }
  }
</style>
