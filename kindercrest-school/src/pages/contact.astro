---
import Footer from '../components/sections/Footer.astro';
import Header from '../components/sections/Header.astro';
import SchoolMap from '../components/islands/SchoolMap.svelte';
import SocialLinks from '../components/ui/SocialLinks.astro';
import { contact, contactForm, getMailtoHref, images, mailSubjects, schoolLocations } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';

const contactHeroStyle = `--contact-hero-image: url('${images.contactClassroom}');`;
---

<BaseLayout
  title="Contact Kindercrest School | Lifecamp, Abuja"
  description="Contact Kindercrest School in Lifecamp, Abuja. Find our address, phone numbers, email, social link, map, and parent enquiry form."
>
  <Header />
  <main id="main-content">
    <section class="contact-hero" aria-labelledby="contact-title" style={contactHeroStyle}>
      <div class="contact-hero__inner">
        <h1 id="contact-title">Contact</h1>
      </div>
    </section>

    <section class="contact-intro" aria-label="Contact introduction">
      <div class="contact-intro__inner">
        <p>
          We welcome enquiries from families throughout the year. Visit Kindercrest, or send us a short message and our
          school team will guide you through the next step.
        </p>
      </div>
    </section>

    <section class="contact-page" aria-label="Kindercrest contact details and enquiry form">
      <div class="contact-page__inner">
        <div class="contact-form-column">
          <div class="contact-section-heading">
            <p>Parent enquiry</p>
            <h2>Send us a message</h2>
          </div>

          <form
            class="contact-form"
            data-contact-form
            data-recipient={contact.email}
            data-subject={mailSubjects.contactForm}
            data-success-message={contactForm.successMessage}
            novalidate
          >
            <label>
              <span>Name</span>
              <input type="text" name="name" autocomplete="name" required />
            </label>

            <label>
              <span>Email</span>
              <input type="email" name="email" autocomplete="email" required />
            </label>

            <label class="contact-form__message">
              <span>Message</span>
              <textarea
                name="message"
                rows="8"
                required
                data-message-field
                data-min-words={contactForm.minWords}
                data-max-words={contactForm.maxWords}
                aria-describedby="message-help message-count"
              ></textarea>
            </label>

            <div class="message-feedback">
              <p class="message-help" id="message-help" data-message-help>
                Aim for {contactForm.minWords} to {contactForm.maxWords} words so we have enough context to respond well.
              </p>
              <p class="message-count" id="message-count" aria-live="polite" data-message-count>
                0 / {contactForm.maxWords} words
              </p>
            </div>

            <button class="contact-form__submit" type="submit">Send Message</button>
            <p class="contact-form__status" aria-live="polite" data-form-status></p>
          </form>
        </div>

        <aside class="contact-side" aria-label="School contact details">
          <div class="contact-section-heading">
            <p>School details</p>
            <h2>Visit or reach us directly</h2>
          </div>

          <address class="contact-details">
            <div class="contact-detail">
              <span>Address</span>
              <p>
                {contact.addressLines.map((line) => <>{line}<br /></>)}
              </p>
            </div>
            <div class="contact-detail">
              <span>Phone</span>
              <p>
                {contact.phones.map((phone) => <><a href={`tel:${phone}`}>{phone}</a><br /></>)}
              </p>
            </div>
            <div class="contact-detail">
              <span>Email</span>
              <p><a href={getMailtoHref()}>{contact.email}</a></p>
            </div>
            <div class="contact-detail">
              <span>Social</span>
              <SocialLinks class="contact-socials" linkClass="contact-social-link" />
            </div>
          </address>
        </aside>
      </div>
    </section>

    <section class="contact-location" aria-labelledby="location-title">
      <div class="contact-location__heading">
        <p>Our locations</p>
        <h2 id="location-title">Find us in Abuja</h2>
      </div>

      <div class="contact-map">
        <SchoolMap
          locations={schoolLocations}
          schoolName={contact.schoolName}
          client:visible
        />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import '../scripts/contact-form';
</script>

<style>
  .contact-hero {
    position: relative;
    display: grid;
    min-height: 100svh;
    overflow: hidden;
    color: var(--kc-white);
    font-family: var(--font-body);
    background-color: var(--kc-navy);
    background-image:
      linear-gradient(90deg, rgb(0 0 0 / 50%) 0%, rgb(0 0 0 / 30%) 48%, rgb(0 0 0 / 50%) 100%),
      linear-gradient(180deg, rgb(0 0 0 / 12%) 0%, rgb(0 0 0 / 14%) 48%, rgb(0 0 0 / 56%) 100%),
      var(--contact-hero-image);
    background-position:
      center,
      center,
      center 42%;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .contact-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    width: min(1920px, calc(100% - (clamp(1.4rem, 3.6vw, 5.6rem) * 2)));
    min-height: 100svh;
    place-items: end start;
    margin-inline: auto;
    padding: clamp(8rem, 15vh, 12rem) 0 clamp(3.6rem, 8vh, 6rem);
  }

  .contact-hero h1 {
    margin: 0;
    color: var(--kc-white);
    font-size: clamp(5rem, 9.5vw, 12.5rem);
    font-weight: 430;
    letter-spacing: 0.08em;
    line-height: 0.9;
    text-transform: uppercase;
  }

  .contact-intro {
    padding-block: clamp(3.6rem, 6vw, 5.8rem);
    color: var(--kc-ink);
    font-family: var(--font-body);
    background: var(--kc-white);
  }

  .contact-intro__inner {
    width: min(1680px, calc(100% - (clamp(1.4rem, 4vw, 4rem) * 2)));
    margin-inline: auto;
  }

  .contact-intro p {
    max-width: 1120px;
    margin: 0;
    color: var(--kc-ink);
    font-size: clamp(2rem, 3.35vw, 4.1rem);
    font-weight: 430;
    letter-spacing: 0;
    line-height: 1.13;
    text-wrap: balance;
  }

  .contact-page {
    padding-block: clamp(4rem, 7vw, 6.5rem);
    color: var(--kc-ink);
    font-family: var(--font-body);
    background:
      linear-gradient(180deg, var(--kc-warm) 0%, var(--kc-warm) 72%, var(--kc-white) 100%);
  }

  .contact-page__inner {
    display: grid;
    width: min(1680px, calc(100% - (clamp(1.4rem, 4vw, 4rem) * 2)));
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.62fr);
    gap: clamp(3rem, 7vw, 7.5rem);
    align-items: start;
    margin-inline: auto;
  }

  .contact-form-column,
  .contact-side {
    display: grid;
    align-content: start;
    gap: clamp(1.85rem, 3vw, 2.75rem);
  }

  .contact-section-heading {
    display: grid;
    gap: 0.75rem;
  }

  .contact-section-heading p {
    margin: 0;
    color: var(--kc-sky);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .contact-section-heading h2 {
    max-width: 640px;
    margin: 0;
    color: var(--kc-navy);
    font-size: clamp(2.35rem, 4vw, 4.4rem);
    font-weight: 430;
    letter-spacing: 0;
    line-height: 0.98;
    text-wrap: balance;
  }

  .contact-details {
    display: grid;
    gap: clamp(1.15rem, 2.2vw, 1.55rem);
    font-style: normal;
  }

  .contact-detail {
    display: grid;
    gap: 0.42rem;
  }

  .contact-detail span {
    color: var(--kc-muted);
    font-size: 0.74rem;
    font-weight: 780;
    letter-spacing: 0.12em;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .contact-detail p {
    margin: 0;
    color: var(--kc-ink);
    font-size: clamp(1.02rem, 1.18vw, 1.13rem);
    font-weight: 560;
    line-height: 1.48;
    overflow-wrap: break-word;
  }

  .contact-detail a {
    position: relative;
    color: inherit;
    text-decoration: none;
    transition:
      color 160ms ease,
      opacity 160ms ease;
  }

  .contact-detail a::after {
    position: absolute;
    right: 0;
    bottom: -0.12rem;
    left: 0;
    height: 1px;
    background: currentColor;
    content: '';
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition:
      opacity 160ms ease,
      transform 180ms ease;
  }

  .contact-detail a:hover,
  .contact-detail a:focus-visible {
    color: var(--kc-navy);
  }

  .contact-detail a:hover::after,
  .contact-detail a:focus-visible::after {
    opacity: 0.72;
    transform: scaleX(1);
  }

  .contact-socials {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .contact-social-link {
    display: inline-flex;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    color: var(--kc-ink);
  }

  .contact-social-link::after {
    display: none;
  }

  .contact-social-link svg {
    width: 1.55rem;
    height: 1.55rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .contact-social-link:hover svg,
  .contact-social-link:focus-visible svg {
    color: var(--kc-navy);
    transform: translateY(-1px);
  }

  .contact-location {
    color: var(--kc-ink);
    font-family: var(--font-body);
    background: var(--kc-white);
  }

  .contact-location__heading {
    display: grid;
    width: min(1680px, calc(100% - (clamp(1.4rem, 4vw, 4rem) * 2)));
    gap: 0.75rem;
    margin-inline: auto;
    padding-block: clamp(3.5rem, 6vw, 5.5rem) clamp(2rem, 3.5vw, 3.25rem);
  }

  .contact-location__heading p {
    margin: 0;
    color: var(--kc-sky);
    font-size: 0.78rem;
    font-weight: 850;
    letter-spacing: 0.14em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .contact-location__heading h2 {
    margin: 0;
    color: var(--kc-navy);
    font-size: clamp(2.35rem, 4vw, 4.4rem);
    font-weight: 430;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .contact-map {
    width: 100%;
    overflow: hidden;
  }

  .contact-form {
    display: grid;
    gap: 1.15rem;
    margin: 0;
  }

  .contact-form label {
    display: grid;
    gap: 0.5rem;
  }

  .contact-form label > span {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    color: var(--kc-ink);
    font-size: 0.86rem;
    font-weight: 760;
    line-height: 1.2;
  }

  .contact-form label > span::after {
    width: 0.46rem;
    height: 0.46rem;
    border-radius: 50%;
    background: var(--kc-magenta);
    content: '';
    opacity: 0;
    transform: scale(0.75);
    transition:
      opacity 140ms ease,
      transform 140ms ease;
  }

  .contact-form label[data-invalid='true'] > span::after {
    opacity: 1;
    transform: scale(1);
  }

  .contact-form :is(input, textarea) {
    width: 100%;
    border: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--kc-navy) 24%, white);
    border-radius: 0;
    padding: 0.98rem 0;
    color: var(--kc-ink);
    background: transparent;
    font: inherit;
    line-height: 1.45;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 190px;
  }

  .contact-form :is(input, textarea):focus {
    border-color: var(--kc-navy);
    outline: 0;
    box-shadow: 0 1px 0 var(--kc-navy);
  }

  .contact-form label[data-invalid='true'] :is(input, textarea) {
    border-color: color-mix(in srgb, var(--kc-magenta) 76%, var(--kc-ink));
  }

  .message-help,
  .message-count,
  .contact-form__status {
    margin: 0;
    color: var(--kc-muted);
    font-size: 0.86rem;
    line-height: 1.45;
  }

  .message-count {
    font-weight: 680;
  }

  .message-feedback {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .contact-form[data-message-state='ready'] .message-help,
  .contact-form[data-message-state='ready'] .message-count {
    color: color-mix(in srgb, var(--kc-green) 70%, var(--kc-ink));
  }

  .contact-form[data-message-state='long'] .message-help,
  .contact-form[data-message-state='long'] .message-count {
    color: color-mix(in srgb, var(--kc-magenta) 72%, var(--kc-ink));
  }

  .contact-form__submit {
    justify-self: start;
    min-height: 3.2rem;
    border: 0;
    border-radius: 0;
    padding: 0 1.55rem;
    color: var(--kc-white);
    background: var(--kc-navy);
    font: inherit;
    font-weight: 760;
    cursor: pointer;
    transition:
      background-color 160ms ease,
      transform 160ms ease;
  }

  .contact-form__submit:hover,
  .contact-form__submit:focus-visible {
    background: var(--kc-royal);
    transform: translateY(-1px);
  }

  .contact-form__status {
    color: var(--kc-navy);
    font-weight: 620;
  }

  @media (max-width: 900px) {
    .contact-hero__inner {
      width: min(100% - 2rem, 680px);
      min-height: 100svh;
      padding: 7.5rem 0 3.5rem;
    }

    .contact-hero h1 {
      font-size: clamp(4rem, 18vw, 7.2rem);
      letter-spacing: 0.055em;
    }

    .contact-intro__inner {
      width: min(100% - 2rem, 680px);
    }

    .contact-intro p {
      font-size: clamp(2rem, 8vw, 3.25rem);
    }

    .contact-page__inner {
      width: min(100% - 2rem, 680px);
      grid-template-columns: 1fr;
      gap: 3.25rem;
    }

    .contact-location__heading {
      width: min(100% - 2rem, 680px);
    }
  }

  @media (max-width: 560px) {
    .contact-page {
      padding-block: 3.25rem 4rem;
    }

    .message-feedback {
      display: grid;
      gap: 0.35rem;
    }

    .contact-form__submit {
      width: 100%;
    }
  }
</style>
